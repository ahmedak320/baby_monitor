# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# Multiple YouTube API keys from separate GCP projects (comma-separated)
# Each key gets 10,000 units/day — 3 keys = 30,000 units/day
YOUTUBE_API_KEYS=key1,key2,key3

# RevenueCat (optional — leave empty for dev mode)
REVENUECAT_API_KEY=

# Public Piped instances for failover (comma-separated, optional)
PIPED_INSTANCES=https://pipedapi.kavin.rocks,https://pipedapi.adminforge.de

# Worker API (optional — for direct analysis triggers)
WORKER_API_URL=http://localhost:8000
WORKER_API_KEY=your-worker-api-key
