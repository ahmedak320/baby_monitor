# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# Multiple YouTube API keys from separate GCP projects (comma-separated)
# Each key gets 10,000 units/day — 3 keys = 30,000 units/day
YOUTUBE_API_KEYS=key1,key2,key3

# Piped API (fallback — single instance, legacy)
PIPED_API_URL=https://pipedapi.kavin.rocks

# Multiple Piped instances for failover (comma-separated)
PIPED_INSTANCES=https://pipedapi.kavin.rocks,https://pipedapi.adminforge.de

# Claude API (for AI analysis)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stripe (for premium subscriptions)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# RevenueCat (for mobile in-app purchases)
REVENUECAT_API_KEY=your-revenuecat-api-key
